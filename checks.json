      "category": "Access_Control",
      "engine": "ldap",
      "searchBase": "Domain",
      "searchScope": "Subtree",
      "ldapFilter": "(&(objectCategory=person)(objectClass=user)(adminCount=1)(!(userAccountControl:1.2.840.113556.1.4.803:=2)))",
      "propertiesToLoad": [
