    {
      "id": "ACC-001",
      "name": "Privileged Users adminCount1",
      "category": "Access_Control",
      "engine": "ldap",
      "searchBase": "Domain",
      "searchScope": "Subtree",
      "ldapFilter": "(&(objectCategory=person)(objectClass=user)(adminCount=1)(!(userAccountControl:1.2.840.113556.1.4.803:=2)))",
      "propertiesToLoad": ["name", "distinguishedName", "samAccountName", "adminCount", "userAccountControl", "objectClass", "whenCreated", "whenChanged"],
      "outputProperties": {
        "Name": "name",
        "DistinguishedName": "distinguishedName",
        "SamAccountName": "samAccountName",
        "AdminCount": "adminCount",
        "UserAccountControl": "userAccountControl",
        "ObjectClass": "objectClass",
        "WhenCreated": "whenCreated",
        "WhenChanged": "whenChanged"
      },
      "sourcePath": "Access_Control/ACC-001_Privileged_Users_adminCount1/adsi.ps1",
      "severity": "high",
      "description": "Misconfiguration: user accounts with adminCount=1 (protected object flag); review for inappropriate persistence of admin protection."
    },
    {
      "id": "ACC-002",
