# LAN / other PCs: leave VITE_API_URL unset in dev so the app uses `/api` (Vite proxy) and works at http://<this-machine-ip>:5173
# Only set this if the API is on another host/port than the page (e.g. production split deployment):
# VITE_API_URL=http://192.168.1.10:3000/api
#
# VITE_API_URL=http://localhost:3000/api
# Optional: backend origin for downloads (no trailing slash)
# VITE_BACKEND_ORIGIN=http://localhost:3000
#
# Optional: override WebSocket URL (default: ws(s)://<same-hostname-as-browser>:3001)
# VITE_WS_URL=ws://localhost:3001
# VITE_WS_PORT=3001
