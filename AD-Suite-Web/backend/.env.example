# Server
NODE_ENV=development
PORT=3000
# Bind on all interfaces so other devices can reach http://<this-pc-ip>:3000 (default 0.0.0.0)
# HOST=0.0.0.0
API_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adsuite
DB_USER=postgres
DB_PASSWORD=your_password

# JWT (use at least 32 characters in production — validated at startup)
JWT_SECRET=your_jwt_secret_key_change_this_to_at_least_32_chars
JWT_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=AD Suite <noreply@adsuite.com>

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=100MB

# PowerShell Scripts
PS_SCRIPT_PATH=../../Invoke-ADSuiteScan.ps1
PS_MODULE_PATH=../../Modules

# WebSocket
WS_PORT=3001

# Scan Settings
DEFAULT_SCAN_TIMEOUT=3600000
MAX_CONCURRENT_SCANS=5

# Checks catalog for Invoke-ADSuiteScan (repo-relative or absolute path)
# AD_SUITE_CHECKS_JSON=checks.json
# CHECKS_JSON_PATH=checks.json

# Frontend URL(s) for CORS — comma-separated if you use both localhost and LAN/DNS, e.g.:
# FRONTEND_URL=http://localhost:5173,http://192.168.1.10:5173,http://myserver.corp.local:5173
FRONTEND_URL=http://localhost:5173
